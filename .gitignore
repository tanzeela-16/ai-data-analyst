# =====================================================================
# Python / Backend Trimming
# =====================================================================
# Virtual environment folder
backend/venv/
venv/

# Python bytecode caches
__pycache__/
backend/__pycache__/
*.py[cod]
*$py.class

# Local environment variables (Crucial for API key security)
.env
.env.local
backend/.env

# =====================================================================
# JavaScript / Frontend Trimming
# =====================================================================
# Node dependencies
node_modules/
frontend/node_modules/

# Production build outputs
dist/
frontend/dist/

# Logs
clean.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# =====================================================================
# Operating System & IDE Garbage
# =====================================================================
# Office/OS overhead
.DS_Store
Thumbs.db
db.lock

# IDE settings
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp